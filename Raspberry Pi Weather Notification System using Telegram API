import urllib.request # 외부 웹 서버에 데이터를 요청하기 위한 라이브러리 호출
import json # 서버로부터 받은 JSON 형식의 데이터를 파이썬 객체로 변환
import datetime # 날짜와 시간을 확인하고 비교
import asyncio # 비동기 처리를 지원하는 라이브러리
from telegram import Bot # 텔레그램 메시지를 전송 할 수 있는 Bot 클래스 선언

telegram_id = 'chat ID' # 메시지를 받을 사용자의 ID 입력
my_token = 'bot token' # 메시지를 받는 사용자의 bot token 입력
api_key = 'API key' # 날씨용 API 키 입력 

bot = Bot(token=my_token) # 설정한 토쿤을 사용하여 봇 객체 작동 

ALERT_HOURS = [7, 10, 13, 16, 19, 22] # 날씨 정보를 원하는 시간대 설정
ALERT_TIMES = ["08:30", "14:45"] # 시:분 단위로 보내기 위한 목록

def getWeather(): # Url을 사용하여 날씨 정보를 가져오기 위한 함수 
    url = f"https://api.openweathermap.org/data/2.5/forecast?q=Seoul&appid={api_key}&units=metric&lang=en&cnt=8"
    # 서울 지역의 날씨 정보 url
    with urllib.request.urlopen(url) as r: 
        data = json.loads(r.read()) # 읽어온 데이터를 파이썬이 이해할 수 있는 딕셔너리 형태로 변환
        
    text = "" # 메시지를 담을 빈 문자열 생성
    for i in range(8): # for 반복문 8번 반복
        item = data['list'][i] # i번째 시간대의 날씨 정보 호출
        hour = str((int(item['dt_txt'][11:13]) + 9) % 24).zfill(2) # 한국 시간대로 변환하고 2자리 숫자로 맞춤
        temp = item['main']['temp'] # 해당 시간대의 온도 가져오기
        humi = item['main']['humidity'] # 해당 시간대의 습도 가져오기 
        desc = item['weather'][0]['description'] # 해당 날의 날씨 설명 가져오기
        text += f"({hour}h {temp}C {humi}% {desc})\n" # 가져온 정보를 한 줄로 만들어서 추가
            
    return text # 완성된 전체 날씨 정보 반환

async def main(): # 시간을 체크하고 알림을 보내는 메인 로직
    try:
        while True: # 코드가 종료될 때 까지 무한 반복 
            now = datetime.datetime.now() # 현재 시스템의 날짜와 시간 호출
            hm = now.strftime('%H:%M') # 현재 시간을 시:분 형태로 바꿈 
            
            is_alert_hour = (now.hour in ALERT_HOURS and now.minute == 0 and now.second == 0) # 정각 알림 조건, 시가 목록에 있고 0분 0초인 경우
            is_alert_time = (hm in ALERT_TIMES and now.second == 0) # 지정 시간 알림 조건, 현재 시:분에 있고 0초인 경우
            
            if is_alert_hour or is_alert_time: # 위 조건 중 하나라도 만족하면 호출
                msg = getWeather() # 날씨 정보 생성 
                print(msg) # 확인을 위해 터미널 창에 내용 출력 
                await bot.send_message(chat_id=telegram_id, text=msg) # 텔레그램 봇을 통해 메시지 전송
            
            await asyncio.sleep(1) # 1초간 휴식 
            
    except KeyboardInterrupt: # Ctrl + C 를 눌러 코드 종료 
        pass

asyncio.run(main()) # 비동기로 작성된 main 함수를 실제로 실행
